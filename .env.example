# Google Cloud Vertex AI Configuration
# Provide the path to your GCP service account JSON credential file (relative to this file, or absolute)
GOOGLE_APPLICATION_CREDENTIALS="./bettrlabs-vertex-ai.json"

# Base configuration for Vertex AI
GCP_PROJECT_ID="your-gcp-project-id"
GCP_LOCATION="us-central1"

# LLM Model Configuration
# For Vertex AI, prefix models with publishers/google/models/ or just use the model name if configured correctly (e.g., gemini-2.5-flash, gemini-2.5-pro)
VALIDATION_MODEL="gemini-2.5-flash"
ANALYSIS_MODEL="gemini-2.5-pro"
CLAIMS_EXTRACTION_MODEL="gemini-2.5-flash"
CLAIMS_VALIDATION_MODEL="gemini-2.5-pro"

# Server Configuration
HOST="0.0.0.0"
PORT="8000"

# CORS Allowed Origins (Comma-separated for multiple)
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
